# =============================================================================
# agentlab.in — Environment Variables
# Copy this file to .env.local and fill in your values.
# =============================================================================

# Phase 0 — required
NODE_ENV=development

# =============================================================================
# Phase 1 — NextAuth.js + GitHub OAuth (add when implementing auth)
# =============================================================================
# NEXTAUTH_SECRET=         # openssl rand -base64 32
# NEXTAUTH_URL=            # http://localhost:3000 (dev) | https://agentlab.in (prod)
# GITHUB_CLIENT_ID=
# GITHUB_CLIENT_SECRET=

# =============================================================================
# Phase 2 — Supabase (add when implementing DB)
# =============================================================================
# NEXT_PUBLIC_SUPABASE_URL=
# NEXT_PUBLIC_SUPABASE_ANON_KEY=
# SUPABASE_SERVICE_ROLE_KEY=

# =============================================================================
# Phase 0.5 — Kit (ConvertKit) waitlist on Coming Soon page
# Set in Vercel Production env. If either is missing, /api/waitlist returns 503.
# =============================================================================
# KIT_API_KEY=        # Kit dashboard → Account Settings → API
# KIT_FORM_ID=        # Numeric form ID from the form's URL or embed code
