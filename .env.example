# =============================================================================
# agentlab.in — Environment Variables
# Copy this file to .env.local and fill in your values.
# =============================================================================

# Phase 0 — required
NODE_ENV=development

# =============================================================================
# Phase 1 — NextAuth.js + GitHub OAuth
# =============================================================================
NEXTAUTH_SECRET=          # openssl rand -base64 32
NEXTAUTH_URL=http://localhost:3010    # dev port is 3010 (next dev -p 3010); prod is https://agentlab.in
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# =============================================================================
# Phase 1 — Supabase (shared with Phase 2+)
# =============================================================================
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# =============================================================================
# Phase 1 — Admin allowlist (comma-separated GitHub logins, no spaces)
# Phase 12 will consume this. Install the scaffold now.
# =============================================================================
ADMIN_GITHUB_LOGINS=harshitsinghbhandari

# =============================================================================
# Phase 14 — Rate limiting (Upstash Redis). Optional: missing values fall back
# to an in-memory sliding window (single-region only, not authoritative).
# =============================================================================
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
